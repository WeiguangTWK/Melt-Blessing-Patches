From b3942499c909fae058c7e955b27821aab80439b2 Mon Sep 17 00:00:00 2001
From: WeiguangTWK <weiguangtwk@outlook.com>
Date: Sun, 22 Feb 2026 19:17:42 +0800
Subject: [PATCH 1/2] mm: make ZRAM use ZBlock

---
 drivers/block/zram/Kconfig    |   7 +++
 drivers/block/zram/zram_drv.c | 113 ++++++++++++++++++++++++++++------
 drivers/block/zram/zram_drv.h |   4 ++
 include/linux/zblock.h        |  20 ++++++
 mm/zblock.c                   |  21 ++++---
 5 files changed, 139 insertions(+), 26 deletions(-)
 create mode 100644 include/linux/zblock.h

diff --git a/drivers/block/zram/Kconfig b/drivers/block/zram/Kconfig
index 87a6ff4c2..bd72485c1 100644
--- a/drivers/block/zram/Kconfig
+++ b/drivers/block/zram/Kconfig
@@ -14,6 +14,13 @@ config ZRAM
 
 	  See Documentation/admin-guide/blockdev/zram.rst for more information.
 
+config ZRAM_USE_ZBLOCK
+	bool "Use zblock as zram primary allocator"
+	depends on ZRAM=y && ZBLOCK=y
+	help
+	  Use zblock as the primary allocator for compressed objects in zram.
+	  zsmalloc remains enabled for large incompressible objects.
+
 config ZRAM_ENTROPY
 	bool "Use entropy optimization for zram"
 	depends on ZRAM && ZRAM_DEF_COMP_ZSTD
diff --git a/drivers/block/zram/zram_drv.c b/drivers/block/zram/zram_drv.c
index ff6385b56..0d59ca540 100644
--- a/drivers/block/zram/zram_drv.c
+++ b/drivers/block/zram/zram_drv.c
@@ -59,6 +59,64 @@ static void zram_free_page(struct zram *zram, size_t index);
 static int zram_bvec_read(struct zram *zram, struct bio_vec *bvec,
 				u32 index, int offset, struct bio *bio);
 
+static unsigned long zram_get_total_pages(struct zram *zram)
+{
+	unsigned long pages = zs_get_total_pages(zram->mem_pool);
+
+#ifdef CONFIG_ZRAM_USE_ZBLOCK
+	pages += zblock_get_total_pages(zram->block_mem_pool);
+#endif
+	return pages;
+}
+
+static unsigned long zram_malloc(struct zram *zram, unsigned int size, gfp_t gfp)
+{
+#ifdef CONFIG_ZRAM_USE_ZBLOCK
+	unsigned long handle = 0;
+
+	if (size != PAGE_SIZE) {
+		if (!zblock_alloc(zram->block_mem_pool, size,
+				  gfp & ~(__GFP_MOVABLE | __GFP_HIGHMEM),
+				  &handle))
+			return handle;
+		return 0;
+	}
+#endif
+	return zs_malloc(zram->mem_pool, size, gfp);
+}
+
+static void zram_free_handle(struct zram *zram, unsigned long handle, unsigned int size)
+{
+#ifdef CONFIG_ZRAM_USE_ZBLOCK
+	if (size != PAGE_SIZE) {
+		zblock_free(zram->block_mem_pool, handle);
+		return;
+	}
+#endif
+	zs_free(zram->mem_pool, handle);
+}
+
+static void *zram_map_handle(struct zram *zram, unsigned long handle,
+			     enum zs_mapmode mm, unsigned int size)
+{
+#ifdef CONFIG_ZRAM_USE_ZBLOCK
+	if (size != PAGE_SIZE)
+		return zblock_map(zram->block_mem_pool, handle);
+#endif
+	return zs_map_object(zram->mem_pool, handle, mm);
+}
+
+static void zram_unmap_handle(struct zram *zram, unsigned long handle, unsigned int size)
+{
+#ifdef CONFIG_ZRAM_USE_ZBLOCK
+	if (size != PAGE_SIZE) {
+		zblock_unmap(zram->block_mem_pool, handle);
+		return;
+	}
+#endif
+	zs_unmap_object(zram->mem_pool, handle);
+}
+
 
 static int zram_slot_trylock(struct zram *zram, u32 index)
 {
@@ -284,7 +342,7 @@ static ssize_t mem_used_max_store(struct device *dev,
 	down_read(&zram->init_lock);
 	if (init_done(zram)) {
 		atomic_long_set(&zram->stats.max_used_pages,
-				zs_get_total_pages(zram->mem_pool));
+				zram_get_total_pages(zram));
 	}
 	up_read(&zram->init_lock);
 
@@ -1087,7 +1145,7 @@ static ssize_t mm_stat_show(struct device *dev,
 
 	down_read(&zram->init_lock);
 	if (init_done(zram)) {
-		mem_used = zs_get_total_pages(zram->mem_pool);
+		mem_used = zram_get_total_pages(zram);
 		zs_pool_stats(zram->mem_pool, &pool_stats);
 	}
 
@@ -1164,6 +1222,9 @@ static void zram_meta_free(struct zram *zram, u64 disksize)
 		zram_free_page(zram, index);
 
 	zs_destroy_pool(zram->mem_pool);
+#ifdef CONFIG_ZRAM_USE_ZBLOCK
+	zblock_destroy_pool(zram->block_mem_pool);
+#endif
 	vfree(zram->table);
 }
 
@@ -1182,8 +1243,21 @@ static bool zram_meta_alloc(struct zram *zram, u64 disksize)
 		return false;
 	}
 
+#ifdef CONFIG_ZRAM_USE_ZBLOCK
+	zram->block_mem_pool = zblock_create_pool(GFP_KERNEL);
+	if (!zram->block_mem_pool) {
+		zs_destroy_pool(zram->mem_pool);
+		vfree(zram->table);
+		return false;
+	}
+#endif
+
 	if (!huge_class_size)
+#ifdef CONFIG_ZRAM_USE_ZBLOCK
+		huge_class_size = zblock_get_max_alloc_size();
+#else
 		huge_class_size = zs_huge_class_size(zram->mem_pool);
+#endif
 	return true;
 }
 
@@ -1227,7 +1301,7 @@ static void zram_free_page(struct zram *zram, size_t index)
 	if (!handle)
 		return;
 
-	zs_free(zram->mem_pool, handle);
+	zram_free_handle(zram, handle, zram_get_obj_size(zram, index));
 
 	atomic64_sub(zram_get_obj_size(zram, index),
 			&zram->stats.compr_data_size);
@@ -1280,7 +1354,7 @@ static int __zram_bvec_read(struct zram *zram, struct page *page, u32 index,
 	if (size != PAGE_SIZE)
 		zstrm = zcomp_stream_get(zram->comp);
 
-	src = zs_map_object(zram->mem_pool, handle, ZS_MM_RO);
+	src = zram_map_handle(zram, handle, ZS_MM_RO, size);
 	if (size == PAGE_SIZE) {
 		dst = kmap_atomic(page);
 		copy_page(dst, src);
@@ -1292,7 +1366,7 @@ static int __zram_bvec_read(struct zram *zram, struct page *page, u32 index,
 		kunmap_atomic(dst);
 		zcomp_stream_put(zram->comp);
 	}
-	zs_unmap_object(zram->mem_pool, handle);
+	zram_unmap_handle(zram, handle, size);
 	zram_slot_unlock(zram, index);
 
 	/* Should NEVER happen. Return bio error if it does. */
@@ -1406,7 +1480,8 @@ static int __zram_bvec_write(struct zram *zram, struct bio_vec *bvec,
 	if (unlikely(ret)) {
 		zcomp_stream_put(zram->comp);
 		pr_err("Compression failed! err=%d\n", ret);
-		zs_free(zram->mem_pool, handle);
+		if (handle)
+			zram_free_handle(zram, handle, comp_len);
 		return ret;
 	}
 
@@ -1426,33 +1501,33 @@ static int __zram_bvec_write(struct zram *zram, struct bio_vec *bvec,
 	 * from the slow path and handle has already been allocated.
 	 */
 	if (!handle)
-		handle = zs_malloc(zram->mem_pool, comp_len,
-				__GFP_KSWAPD_RECLAIM |
-				__GFP_NOWARN |
-				__GFP_HIGHMEM |
-				__GFP_MOVABLE |
-				__GFP_CMA);
+		handle = zram_malloc(zram, comp_len,
+				     __GFP_KSWAPD_RECLAIM |
+				     __GFP_NOWARN |
+				     __GFP_HIGHMEM |
+				     __GFP_MOVABLE |
+				     __GFP_CMA);
 	if (!handle) {
 		zcomp_stream_put(zram->comp);
 		atomic64_inc(&zram->stats.writestall);
-		handle = zs_malloc(zram->mem_pool, comp_len,
-				GFP_NOIO | __GFP_HIGHMEM |
-				__GFP_MOVABLE | __GFP_CMA);
+		handle = zram_malloc(zram, comp_len,
+				     GFP_NOIO | __GFP_HIGHMEM |
+				     __GFP_MOVABLE | __GFP_CMA);
 		if (handle)
 			goto compress_again;
 		return -ENOMEM;
 	}
 
-	alloced_pages = zs_get_total_pages(zram->mem_pool);
+	alloced_pages = zram_get_total_pages(zram);
 	update_used_max(zram, alloced_pages);
 
 	if (zram->limit_pages && alloced_pages > zram->limit_pages) {
 		zcomp_stream_put(zram->comp);
-		zs_free(zram->mem_pool, handle);
+		zram_free_handle(zram, handle, comp_len);
 		return -ENOMEM;
 	}
 
-	dst = zs_map_object(zram->mem_pool, handle, ZS_MM_WO);
+	dst = zram_map_handle(zram, handle, ZS_MM_WO, comp_len);
 
 	src = zstrm->buffer;
 	if (comp_len == PAGE_SIZE)
@@ -1462,7 +1537,7 @@ static int __zram_bvec_write(struct zram *zram, struct bio_vec *bvec,
 		kunmap_atomic(src);
 
 	zcomp_stream_put(zram->comp);
-	zs_unmap_object(zram->mem_pool, handle);
+	zram_unmap_handle(zram, handle, comp_len);
 	atomic64_add(comp_len, &zram->stats.compr_data_size);
 out:
 	/*
diff --git a/drivers/block/zram/zram_drv.h b/drivers/block/zram/zram_drv.h
index f2fd46daa..b3ef05113 100644
--- a/drivers/block/zram/zram_drv.h
+++ b/drivers/block/zram/zram_drv.h
@@ -17,6 +17,7 @@
 
 #include <linux/rwsem.h>
 #include <linux/zsmalloc.h>
+#include <linux/zblock.h>
 #include <linux/crypto.h>
 
 #include "zcomp.h"
@@ -92,6 +93,9 @@ struct zram_stats {
 struct zram {
 	struct zram_table_entry *table;
 	struct zs_pool *mem_pool;
+#ifdef CONFIG_ZRAM_USE_ZBLOCK
+	struct zblock_pool *block_mem_pool;
+#endif
 	struct zcomp *comp;
 	struct gendisk *disk;
 	/* Prevent concurrent execution of device init */
diff --git a/include/linux/zblock.h b/include/linux/zblock.h
new file mode 100644
index 000000000..d9ae40e3b
--- /dev/null
+++ b/include/linux/zblock.h
@@ -0,0 +1,20 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+#ifndef _LINUX_ZBLOCK_H
+#define _LINUX_ZBLOCK_H
+
+#include <linux/gfp.h>
+#include <linux/types.h>
+
+struct zblock_pool;
+
+struct zblock_pool *zblock_create_pool(gfp_t gfp);
+void zblock_destroy_pool(struct zblock_pool *pool);
+int zblock_alloc(struct zblock_pool *pool, size_t size, gfp_t gfp,
+		unsigned long *handle);
+void zblock_free(struct zblock_pool *pool, unsigned long handle);
+void *zblock_map(struct zblock_pool *pool, unsigned long handle);
+void zblock_unmap(struct zblock_pool *pool, unsigned long handle);
+u64 zblock_get_total_pages(struct zblock_pool *pool);
+size_t zblock_get_max_alloc_size(void);
+
+#endif /* _LINUX_ZBLOCK_H */
diff --git a/mm/zblock.c b/mm/zblock.c
index 434bce72a..0f1aaf176 100644
--- a/mm/zblock.c
+++ b/mm/zblock.c
@@ -23,6 +23,7 @@
 #include <linux/preempt.h>
 #include <linux/slab.h>
 #include <linux/spinlock.h>
+#include <linux/zblock.h>
 #include <linux/zpool.h>
 #include "zblock.h"
 
@@ -122,7 +123,7 @@ static struct zblock_block *alloc_block(struct zblock_pool *pool,
  * Return: pointer to the new zblock pool or NULL if the metadata allocation
  * failed.
  */
-static struct zblock_pool *zblock_create_pool(gfp_t gfp)
+struct zblock_pool *zblock_create_pool(gfp_t gfp)
 {
 	struct zblock_pool *pool;
 	struct block_list *block_list;
@@ -148,7 +149,7 @@ static struct zblock_pool *zblock_create_pool(gfp_t gfp)
  * @pool:	the zblock pool to be destroyed
  *
  */
-static void zblock_destroy_pool(struct zblock_pool *pool)
+void zblock_destroy_pool(struct zblock_pool *pool)
 {
 	kfree(pool);
 }
@@ -165,7 +166,7 @@ static void zblock_destroy_pool(struct zblock_pool *pool)
  * gfp arguments are invalid or -ENOMEM if the pool was unable to allocate
  * a new slot.
  */
-static int zblock_alloc(struct zblock_pool *pool, size_t size, gfp_t gfp,
+int zblock_alloc(struct zblock_pool *pool, size_t size, gfp_t gfp,
 			unsigned long *handle)
 {
 	int block_type = -1;
@@ -221,7 +222,7 @@ static int zblock_alloc(struct zblock_pool *pool, size_t size, gfp_t gfp,
  * @handle:	handle associated with the allocation returned by zblock_alloc()
  *
  */
-static void zblock_free(struct zblock_pool *pool, unsigned long handle)
+void zblock_free(struct zblock_pool *pool, unsigned long handle)
 {
 	unsigned int slot, block_type;
 	struct zblock_block *block;
@@ -252,7 +253,7 @@ static void zblock_free(struct zblock_pool *pool, unsigned long handle)
  *
  * Returns: a pointer to the mapped allocation
  */
-static void *zblock_map(struct zblock_pool *pool, unsigned long handle)
+void *zblock_map(struct zblock_pool *pool, unsigned long handle)
 {
 	unsigned int block_type, slot;
 	struct zblock_block *block;
@@ -270,7 +271,7 @@ static void *zblock_map(struct zblock_pool *pool, unsigned long handle)
  * @pool:	pool in which the allocation resides
  * @handle:	handle associated with the allocation to be unmapped
  */
-static void zblock_unmap(struct zblock_pool *pool, unsigned long handle)
+void zblock_unmap(struct zblock_pool *pool, unsigned long handle)
 {
 }
 
@@ -280,7 +281,7 @@ static void zblock_unmap(struct zblock_pool *pool, unsigned long handle)
  *
  * Returns: size in bytes of the given pool.
  */
-static u64 zblock_get_total_pages(struct zblock_pool *pool)
+u64 zblock_get_total_pages(struct zblock_pool *pool)
 {
 	u64 total_size;
 	int i;
@@ -292,6 +293,11 @@ static u64 zblock_get_total_pages(struct zblock_pool *pool)
 	return total_size;
 }
 
+size_t zblock_get_max_alloc_size(void)
+{
+	return block_desc[ARRAY_SIZE(block_desc) - 1].slot_size;
+}
+
 /*****************
  * zpool
  ****************/
@@ -395,6 +401,7 @@ static int __init init_zblock(void)
 {
 	int ret = create_rbtree();
 
+	pr_info("ZBLOCK INIT\n");
 	if (ret)
 		return ret;
 
